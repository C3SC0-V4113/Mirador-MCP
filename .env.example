# Token that MCP clients must send as:
# Authorization: Bearer <MCP_API_KEY>
#
# Generate a real value locally with one of:
# - Node: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# - PowerShell: [Convert]::ToBase64String([Security.Cryptography.RandomNumberGenerator]::GetBytes(32)).TrimEnd('=').Replace('+','-').Replace('/','_')
MCP_API_KEY="replace-with-a-long-random-token"

# Local development example:
# CORE_INTERNAL_URL="http://localhost:3000"
#
# Railway production should use mirador-core's private internal URL, not the public URL.
CORE_INTERNAL_URL="http://localhost:3000"

# Must match the service-to-service token configured in mirador-core.
CORE_SERVICE_TOKEN="replace-with-the-core-service-token"

# Railway injects PORT automatically. Local default is 3000.
PORT="3001"
